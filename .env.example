# ScrapeGraphAI v2 Extract — never commit real keys
SCRAPEGRAPH_API_KEY=sgai-your-key-here
SCRAPEGRAPH_EXTRACT_URL=https://v2-api.scrapegraphai.com/api/extract

# Safer defaults for development (no credits burned)
DRY_RUN_EXTRACT=true
MOCK_GOOGLE=true
# Leave unset for default https://example.com in code; set to empty to force "no URL" tests
MOCK_WEBSITE_URL=https://example.com

# --- Website discovery (~20k scale) ---
# Recommended: Google Programmable Search (Custom Search JSON API)
# https://developers.google.com/custom-search/v1/overview
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
# Pace calls to stay under quota (seconds between CSE requests)
CSE_DELAY_S=0.25

# SEARCH_PROVIDER: auto | cse | duckduckgo | playwright  (legacy: google → playwright)
# auto: CSE if keys set, else DuckDuckGo HTML; optional Playwright if SEARCH_PLAYWRIGHT_FALLBACK=true
# Free path (client): duckduckgo — no paid search API
SEARCH_PROVIDER=duckduckgo
DDG_DELAY_S=5
DDG_API_RETRIES=4
DDG_USE_HTML_FALLBACK=false
SEARCH_PLAYWRIGHT_FALLBACK=false

# Playwright (google.com) — dev / last resort only; CAPTCHA at scale
GOOGLE_DELAY_MIN=2.0
GOOGLE_DELAY_MAX=6.0
# PLAYWRIGHT_PROXY_SERVER=
