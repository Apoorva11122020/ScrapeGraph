# ScrapeGraphAI v2 Extract — never commit real keys
SCRAPEGRAPH_API_KEY=sgai-your-key-here
SCRAPEGRAPH_EXTRACT_URL=https://v2-api.scrapegraphai.com/api/extract

# Safer defaults for development (no credits burned, no live search)
DRY_RUN_EXTRACT=true
MOCK_GOOGLE=true
MOCK_WEBSITE_URL=https://example.com

# --- URL Discovery (googlesearch-python) ---
# Delay between Google searches (seconds) — keep 8-12s for 90 companies
GOOGLE_SEARCH_DELAY_S=10

# Playwright fallback if Google rate-limits (true = enabled)
USE_PLAYWRIGHT_FALLBACK=true

# --- For 20K scale (future) ---
# Google Programmable Search (Custom Search JSON API)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
CSE_DELAY_S=0.25

# Optional: proxy for Playwright
# PLAYWRIGHT_PROXY_SERVER=
