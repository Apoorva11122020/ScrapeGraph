# ─── ScrapeAI Configuration ───

# ScrapeGraphAI Extract API (for email/contact extraction step)
SCRAPEGRAPH_API_KEY=
SCRAPEGRAPH_EXTRACT_URL=https://v2-api.scrapegraphai.com/api/extract

# Development safety — set to false when ready to run for real
DRY_RUN_EXTRACT=true
MOCK_GOOGLE=true

# Optional: proxy for Playwright (if your IP gets blocked)
# PLAYWRIGHT_PROXY_SERVER=http://user:pass@proxy:port
